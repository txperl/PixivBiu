{
    "name": "multiverse-v3",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "paraglide:compile": "paraglide-js compile --project ./src/i18n/project.inlang --outdir ./src/i18n/generated --emit-ts-declarations",
        "gen:api": "openapi-typescript http://127.0.0.1:4001/openapi.json -o ./src/lib/api/schema.gen.ts",
        "postinstall": "bun run paraglide:compile",
        "build": "bun run paraglide:compile && tsc -b && vite build",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "check": "biome check --write .",
        "check:unsafe": "biome check --write --unsafe .",
        "preview": "vite preview",
        "shadcn:init": "bunx shadcn@latest init"
    },
    "dependencies": {
        "@base-ui/react": "^1.4.1",
        "@fontsource-variable/google-sans": "^5.2.1",
        "@hugeicons/core-free-icons": "^4.1.4",
        "@hugeicons/react": "^1.1.6",
        "@inlang/paraglide-js": "^2.18.0",
        "@material/material-color-utilities": "^0.4.0",
        "@tailwindcss/vite": "^4.3.0",
        "animejs": "^4.4.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "openapi-fetch": "^0.17.0",
        "react": "^19.2.6",
        "react-day-picker": "^10.0.1",
        "react-dom": "^19.2.6",
        "react-resizable-panels": "^4.11.1",
        "react-router": "^7.15.1",
        "shadcn": "^4.7.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "@inlang/plugin-message-format": "^4.4.0",
        "@types/node": "^25.8.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "openapi-typescript": "^7.13.0",
        "typescript": "~6.0.2",
        "vite": "^8.0.13"
    }
}
